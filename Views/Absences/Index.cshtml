@model IEnumerable<PFE.Models.Absence>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Justifie)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Motif)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IddetailNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Justifie)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Motif)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IddetailNavigation.Iddetail)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Idabsence">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Idabsence">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Idabsence">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

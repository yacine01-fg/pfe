@model IEnumerable<PFE.Models.Pointage>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Datep)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Type)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdemployeNavigation)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IdperiNavigation)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Datep)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Type)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdemployeNavigation.Idemp)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IdperiNavigation.Idperi)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Idp">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Idp">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Idp">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
